# Foundry-backed model endpoint (Azure OpenAI compatible)
FOUNDRY_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
FOUNDRY_MODEL_DEPLOYMENT_NAME=<your-deployment-name>
FOUNDRY_API_KEY=<your-api-key>

# API service settings
AI_API_PORT=8787
AI_API_CORS_ORIGIN=http://localhost:4173

# Tracing (only AI endpoints)
AI_API_TRACING_ENABLED=1
AI_API_TRACING_ENDPOINT=http://localhost:4318/v1/traces
AI_API_SERVICE_NAME=tarot-sprint-ai-api
