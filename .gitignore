# Repo hard-scope: only track project files for QueenCity Soundboard
*

# allow git internals and key root docs
!.gitignore
!README.md
!HEARTBEAT.md
!AGENTS.md
!TOOLS.md
!api-ratelimit.md
!RATE_LIMIT_PROBLEM_REPORT.md

# allow selected local operator docs for heartbeat/runtime tracking
!memory/
!memory/memory.md
!memory/2026-03-25-bootstrap-memory-pack.md
!memory/2026-03-28.md
!openclaw/
!openclaw/LANGGRAPH_CASE_STUDY.md

# track only project directory
!queencity-soundboard/
!queencity-soundboard/**

# track selected Amazon Granite product-surface files
!amazon-granite/
!amazon-granite/frontend/
!amazon-granite/frontend/components/
!amazon-granite/frontend/components/SupplierHero.jsx
!amazon-granite/frontend/data/
!amazon-granite/frontend/data/featured-stones.json
!amazon-granite/frontend/styles/
!amazon-granite/frontend/styles/globals.css
!amazon-granite/frontend/tests/
!amazon-granite/frontend/tests/home-page.test.jsx
!amazon-granite/frontend/public/
!amazon-granite/frontend/public/materials/
!amazon-granite/frontend/public/materials/quartamerica/
!amazon-granite/frontend/public/materials/quartamerica/Calacatta Rio_3cm_quartz.png

# track tarot sprint mock app
!tarot-sprint-mock/
!tarot-sprint-mock/**
.vercel

# -----------------------------
# Security and secrets (global)
# -----------------------------
**/.env
**/.env.*
**/*.env.enc
**/*.env.key
**/credentials/**
**/secrets/**
**/*.secret*
**/*.token*
**/*apikey*
**/*api_key*

# Private keys and certificates
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.p7b
**/*.der
**/*.crt
**/*.csr
**/*.jks
**/*.keystore
**/*id_rsa*
**/*id_ed25519*

# Logs, dumps, and local data
**/*.log
**/*.sqlite
**/*.sqlite3
**/*.db
**/*.jsonl
**/logs/**
**/tmp/**
**/cache/**

# Dependency and build artifacts
**/node_modules/**
**/dist/**
**/build/**
**/coverage/**
**/.pytest_cache/**
**/__pycache__/**
**/.venv/**
**/venv/**
