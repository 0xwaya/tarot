# QueenCity Soundboard — Environment Variables Template
# Copy this to .env and fill in real values.
# NEVER commit .env — only .env.example and .env.encrypted are safe to commit.

# ── Supabase ──────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# WARNING: service role key must NEVER be used client-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Vercel / Deployment ───────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Ticket Tailor ─────────────────────────────────────────
TICKET_TAILOR_API_KEY=your-ticket-tailor-api-key
TICKET_TAILOR_WEBHOOK_SECRET=your-webhook-secret

# ── Stripe (if used directly) ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App config ────────────────────────────────────────────
NODE_ENV=development
