# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep real envs private, allow template)
.env*
!.env.example

# Encrypted env bundles and keys (never commit)
*.env.enc
*.env.key

# Secrets and tokens
*.secret*
*.token*
*apikey*
*api_key*

# Keys, certs, keystores
*.pem
*.p12
*.pfx
*.p7b
*.der
*.crt
*.csr
*.jks
*.keystore
*id_rsa*
*id_ed25519*

# Logs and local data
logs/
cache/
tmp/
*.log
*.sqlite
*.sqlite3
*.db
*.jsonl

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
